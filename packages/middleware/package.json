{
  "name": "@sentence-bank/middleware",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json --resolve-full-paths",
    "clean": "rm -rf dist tsconfig.build.tsbuildinfo",
    "dev": "nodemon --quiet --watch src --ext ts --exec \"tsx src/index.ts\"",
    "start": "node dist/index.js",
    "test": "LOG_LEVEL=silent node --test --import tsx \"./src/tests/**/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "dotenv -e .env -- tsx src/db/migrate.ts",
    "studio": "dotenv -e .env -- drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1089.0",
    "@fastify/cors": "11.1.0",
    "@fastify/multipart": "10.1.0",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "5.2.5",
    "@sentence-bank/types": "workspace:*",
    "dotenv": "17.2.3",
    "dotenv-cli": "11.0.0",
    "drizzle-orm": "0.45.2",
    "fastify": "5.8.5",
    "fflate": "^0.8.3",
    "jimp": "^1.6.1",
    "kuroshiro": "^1.2.0",
    "kuroshiro-analyzer-kuromoji": "^1.1.0",
    "pg": "8.16.3",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/pg": "8.15.6",
    "@types/sql.js": "^1.4.11",
    "drizzle-kit": "0.31.10",
    "nodemon": "3.1.14",
    "tsc-alias": "1.8.16",
    "tsx": "4.20.6",
    "typescript": "5.9.3"
  }
}
