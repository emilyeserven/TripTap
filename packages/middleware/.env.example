# PostgreSQL connection string used by Drizzle and the Fastify API.
# Matches the local docker-compose database (see repo-root docker-compose.yml).
DATABASE_URL=postgresql://postgres:password@localhost:5432/sentence_bank

# Optional: override the API port (defaults to 3001).
# PORT=3001

# --- OCR (Capture feature) ---
# The middleware supports multiple OCR backends and tries them in order with automatic fallback.
# Configure any subset; /api/ocr returns 503 only when NONE are configured.
#
# The two cloud API keys can also be set at runtime on the Settings page (stored in the DB), which
# takes precedence over the OCR_SPACE_API_KEY / GOOGLE_VISION_API_KEY variables below. The env vars
# are a fallback for headless setups; the DB Settings are the primary path.

# Backend 1 (default first): the self-hosted OCR service (see ocr-service/), typically on a LAN
# machine. The port must match OCR_PORT set on that machine.
# OCR_SERVICE_URL=http://192.168.1.50:8422

# Backend 2: OCR.space cloud API (https://ocr.space/ocrapi). Free tier: 25k requests/month, no card.
# (Preferred: set the key on the Settings page instead.)
# OCR_SPACE_API_KEY=your_api_key
# OCR_SPACE_ENGINE=2          # optional: OCR engine (2 supports Japanese incl. vertical text)
# OCR_SPACE_LANGUAGE=jpn      # optional: OCR.space language code
# OCR_SPACE_URL=https://api.ocr.space/parse/image   # optional: endpoint override

# Backend 3: Google Cloud Vision (DOCUMENT_TEXT_DETECTION). Best CJK accuracy. 1k requests/month free.
# Use a Cloud API key with the Vision API enabled. (Preferred: set the key on the Settings page.)
# GOOGLE_VISION_API_KEY=your_api_key
# GOOGLE_VISION_URL=https://vision.googleapis.com/v1/images:annotate   # optional: endpoint override

# Optional: override which backends are used and their fallback order (comma-separated provider ids).
# Ids: self-hosted, ocr-space, google-vision. Unset → all configured backends in the order above.
# OCR_PROVIDERS=self-hosted,ocr-space

# ── Bookmarks tag/taxonomy integration ─────────────────────────────────────────────────────────
# Base URL of the external bookmarks API whose tags/taxonomies are borrowed to tag sentences. The
# Settings-page value (stored in the DB) overrides this; unset falls back to a built-in default. The
# host must be reachable from the middleware (e.g. on the same Tailnet); all calls go server-side.
# BOOKMARKS_API_URL=https://eserve-raspi.seahorse-butterfly.ts.net

# ── Dictionary lookup (Lesson word notes) ──────────────────────────────────────────────────────
# Backs the "Look up" button in a lesson's word notes (/api/dictionary/search). All calls go
# server-side. Two providers are supported and normalize to the same result shape:
#   jisho  — Jisho.org's unofficial JSON API (default). No auth, but unofficial and may be
#            rate-limited or blocked; must be reachable from the middleware.
#   jotoba — a Jotoba instance (self-hostable, official API). Point DICTIONARY_API_URL at it.
# The Settings-page values (stored in the DB) override these; unset falls back to Jisho.
# /api/dictionary/search returns 502 when the host is unreachable.
# DICTIONARY_API_URL=https://jisho.org
# DICTIONARY_PROVIDER=jisho      # or "jotoba"

# ── Tatoeba example sentences (Drill mistakes → add a sentence) ─────────────────────────────────
# Backs "Find examples" when adding a My Sentence from a drill mistake (/api/tatoeba/search). No auth.
# Optional: override the API base URL (defaults to the public host). Sentences are CC-BY 2.0 FR.
# TATOEBA_API_URL=https://tatoeba.org

# ── Media object storage (Migaku import) ───────────────────────────────────────────────────────
# S3-compatible storage (e.g. a Garage instance) for audio/image imported from Migaku/Anki .apkg
# decks. Sentences/vocab store only a small object key; the blobs live here. Give TripTap its own
# dedicated bucket with a scoped access key so the orphan-reconciliation sweep can safely delete
# anything unreferenced in it. When unset, the Migaku import feature returns 503.
#   Garage setup: `garage bucket create triptap-media`, `garage key create triptap`,
#   `garage bucket allow --read --write triptap-media --key triptap`.
# S3_ENDPOINT=https://garage.example.ts.net
# S3_ACCESS_KEY_ID=your_access_key
# S3_SECRET_ACCESS_KEY=your_secret_key
# S3_BUCKET=triptap-media
# S3_REGION=garage                # optional: defaults to "garage"
# S3_FORCE_PATH_STYLE=true        # optional: defaults to true (required for Garage)
