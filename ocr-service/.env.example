# Copy to `.env` and adjust. server.py loads this file automatically.

# Port the OCR service binds. Change it if another service on this machine already
# uses 8000 (check with: netstat -ano | findstr :8000).
OCR_PORT=8000

# Bind address. Keep 0.0.0.0 so the Raspberry Pi can reach it over the LAN.
OCR_HOST=0.0.0.0

# Japanese blocks recognized below this confidence are re-read by manga-ocr.
OCR_CONFIDENCE_THRESHOLD=0.8
